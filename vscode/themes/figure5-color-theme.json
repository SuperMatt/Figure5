  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#8A6448" }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#6CB200" }
    },
    {
      "name": "String escape / regexp",
      "scope": ["constant.character.escape", "string.regexp", "string.regexp.character-class"],
      "settings": { "foreground": "#8ED400" }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#FFB820" }
    },
    {
      "name": "Boolean",
      "scope": ["constant.language.boolean"],
      "settings": { "foreground": "#FFB820" }
    },
    {
      "name": "Null / undefined",
      "scope": ["constant.language.null", "constant.language.undefined", "constant.language"],
      "settings": { "foreground": "#C04880" }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#B84078" }
    },
    {
      "name": "Control flow",
      "scope": ["keyword.control", "keyword.operator.new", "keyword.operator.delete"],
      "settings": { "foreground": "#B84078" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator", "punctuation.separator", "punctuation.terminator"],
      "settings": { "foreground": "#CDBA90" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#CDBA90" }
    },
    {
      "name": "Function name",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic",
        "support.function"
      ],
      "settings": { "foreground": "#4878C8" }
    },
    {
      "name": "Function macro",
      "scope": ["entity.name.function.macro", "support.function.macro"],
      "settings": { "foreground": "#5080D0" }
    },
    {
      "name": "Class / Type",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.name.struct",
        "entity.name.enum",
        "entity.name.interface",
        "entity.name.trait",
        "support.class",
        "support.type"
      ],
      "settings": { "foreground": "#5A90A0" }
    },
    {
      "name": "Type annotation / builtin type",
      "scope": ["support.type.primitive", "support.type.builtin", "keyword.type"],
      "settings": { "foreground": "#5A90A0" }
    },
    {
      "name": "Constructor",
      "scope": ["entity.name.function.constructor", "meta.function.constructor"],
      "settings": { "foreground": "#5080D0" }
    },
    {
      "name": "Namespace / module",
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": { "foreground": "#FFB820" }
    },
    {
      "name": "Constant",
      "scope": ["variable.other.constant", "constant.other"],
      "settings": { "foreground": "#C04880" }
    },
    {
      "name": "Built-in constant",
      "scope": ["constant.language", "support.constant"],
      "settings": { "foreground": "#C04880" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": { "foreground": "#F0E0B8" }
    },
    {
      "name": "Built-in variable / self / this",
      "scope": ["variable.language", "variable.parameter.function.language.special"],
      "settings": { "foreground": "#68A8B8" }
    },
    {
      "name": "Object member / property",
      "scope": ["variable.other.member", "variable.other.property", "support.variable.property"],
      "settings": { "foreground": "#68A8B8" }
    },
    {
      "name": "Enum variant",
      "scope": ["variable.other.enummember", "constant.other.caps"],
      "settings": { "foreground": "#68A8B8" }
    },
    {
      "name": "Attribute / decorator",
      "scope": [
        "entity.other.attribute-name",
        "meta.attribute",
        "keyword.decorator",
        "punctuation.definition.annotation"
      ],
      "settings": { "foreground": "#E0961A" }
    },
    {
      "name": "Label",
      "scope": ["entity.name.label"],
      "settings": { "foreground": "#E0961A" }
    },
    {
      "name": "HTML tag",
      "scope": ["entity.name.tag", "meta.tag.sgml"],
      "settings": { "foreground": "#CC2211" }
    },
    {
      "name": "HTML attribute",
      "scope": ["entity.other.attribute-name.html"],
      "settings": { "foreground": "#E0961A" }
    },
    {
      "name": "CSS property",
